# =====================================================================
# MCP SQL Server (Read-Only) - Plantilla de variables de entorno
# Copiar este archivo a `.env` y completar los valores reales.
# NUNCA commitear el archivo `.env` real.
# =====================================================================

# --- Conexión a SQL Server ---
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=NombreDeTuBaseDeDatos
SQLSERVER_USER=mcp_reader
SQLSERVER_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server

# Cifrado TLS hacia SQL Server.
# En producción mantener ENCRYPT=yes y TRUST_SERVER_CERT=no (con cert válido).
SQLSERVER_ENCRYPT=yes
SQLSERVER_TRUST_SERVER_CERT=no

# Si el servidor expone una réplica de solo lectura (Always On AG),
# se recomienda usar ApplicationIntent=ReadOnly:
SQLSERVER_APPLICATION_INTENT=ReadOnly

# --- Límites operativos del MCP ---
# Timeout (segundos) por consulta. No subir para "tapar" consultas pesadas.
MCP_QUERY_TIMEOUT_SECONDS=15

# Tope absoluto de filas que el MCP puede devolver en cualquier tool.
MCP_MAX_ROWS=100

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
MCP_LOG_LEVEL=INFO
# Ruta del archivo de log. Vacío = solo stderr.
MCP_LOG_FILE=mcp_sqlserver.log
